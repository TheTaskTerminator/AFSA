      "name": "订单导出接口",
      "spec": {
        "method": "POST",
        "path": "/api/orders/export",
        "request": {
          "type": "object",
          "properties": {
            "filters": {
              "type": "object",
              "description": "筛选条件"
            },
            "format": {
              "type": "string",
              "enum": ["xlsx", "csv"],
              "default": "xlsx"
