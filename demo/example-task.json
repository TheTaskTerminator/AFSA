            "fields": {
              "type": "array",
              "items": {"type": "string"},
              "default": ["id", "orderNo", "customerName", "amount", "status", "createdAt"]
            }
          }
        },
        "response": {
          "type": "file",
          "contentType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
          "headers": {
            "Content-Disposition": "attachment; filename=\"orders_export.xlsx\""
          }
        }
      },
      "constraints": {
        "framework": "fastapi",
        "authentication": true,
        "rateLimit": "10/minute"
      }
    },
    {
      "type": "model",
      "name": "订单数据模型扩展",
      "spec": {
        "model": "Order",
        "fields": [
          {"name": "id", "type": "UUID", "required": true},
          {"name": "orderNo", "type": "String", "required": true},
          {"name": "customerName", "type": "String", "required": true},
          {"name": "amount", "type": "Decimal", "required": true},
          {"name": "status", "type": "Enum", "values": ["pending", "processing", "completed", "cancelled"]},
          {"name": "createdAt", "type": "DateTime", "required": true}
        ]
      },
      "constraints": {
        "orm": "sqlalchemy",
        "database": "postgresql"
      }
    }
  ],
  
